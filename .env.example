JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER=your@email.com
JIRA_API_TOKEN=your_api_token
JIRA_DEFAULT_PROJECT=

# LLM Provider: "huggingface" (default, free) or "anthropic"
LLM_PROVIDER=huggingface

# HuggingFace — required when LLM_PROVIDER=huggingface
# Free token: https://huggingface.co/settings/tokens
# Recommended free model: Qwen/Qwen2.5-7B-Instruct (strong at JSON output)
HF_API_KEY=hf_...
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Anthropic — required when LLM_PROVIDER=anthropic
# To use: set LLM_PROVIDER=anthropic and provide your API key below
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-sonnet-4-6
